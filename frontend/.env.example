# Configuration EmailJS pour l'envoi d'emails
# Voir EMAIL_SETUP_GUIDE.md pour les instructions de configuration

# EmailJS Service ID (obtenu après connexion du service Gmail)
VITE_EMAILJS_SERVICE_ID=service_your_id

# EmailJS Template ID (obtenu après création du template)
VITE_EMAILJS_TEMPLATE_ID=template_your_id

# EmailJS Public Key (obtenu dans Account > General)
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Instructions:
# 1. Copier ce fichier en .env
# 2. Remplacer les valeurs par vos propres IDs EmailJS
# 3. Ne jamais commiter le fichier .env dans Git
